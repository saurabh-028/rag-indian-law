# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environment
.venv/
venv/
env/

# Environment variables
.env
.env.*

# FAISS index (large binary files — rebuild with build_index.py)
index/

# Chat memory SQLite DB (local dev / EC2 volume-mounted — real user data)
# NOTE: scoped to the specific runtime file, not a blanket "data/" rule —
# this repo's data/ directory at the root also holds the pipeline's real
# source documents (PDFs/JSONs), which must stay tracked in git.
/data/chat_history.db
*.db
*.db-journal

# Evaluation outputs
evaluation/results/

# Jupyter notebooks and associated build artefacts
.ipynb_checkpoints/
*.ipynb
Notebooks/

# Claude Code session data
.claude/

# Private keys / certificates — never commit
*.pem
*.key
*.p12
*.pfx

# Temporary / scratch folders
New folder/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Logs
*.log
